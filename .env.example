# ---------- Required ----------

# Absolute host path to your Calibre library. Bind-mounted to /books inside the
# container — the app always reads from /books regardless of this value, so
# this variable is host-side only (used by compose.yml's bind mount source).
LIBRARY_HOST_PATH=/absolute/path/to/your/Calibre Library

# Host UID/GID to run the container process as. Run `id` on the host to find yours.
PUID=1000
PGID=1000

# IANA timezone (used for snapshot date-stamping).
TZ=Europe/London


# ---------- Optional ----------

# Port the app listens on (host:container).
CALIBRE_WEB_CLI_PORT=8084

# Single password for HTTP basic auth. Leave empty to disable auth (LAN-only trust).
# WARNING: basic-auth is cleartext over plain HTTP — put behind a TLS reverse proxy
# if you expose this beyond a trusted LAN.
CALIBRE_WEB_CLI_PASSWORD=

# Comma-separated list of metadata source plugin names enabled in fetch-ebook-metadata.
# Supported: Amazon, Google, OpenLibrary. (Goodreads disabled — API shutdown.)
CALIBRE_WEB_CLI_METADATA_SOURCES=Amazon,Google

# Preferred format order when sending a book to the e-reader (first match wins).
CALIBRE_WEB_CLI_DEVICE_FORMAT_ORDER=EPUB,AZW3,MOBI,PDF

# Default page size for the library grid (user-settable per-session via ?per_page=).
CALIBRE_WEB_CLI_PAGE_SIZE=48

# Comma-separated list of allowed device USB IDs (format `vid:pid`, lowercase hex,
# e.g. `1949:9981` for Kindle Paperwhite). Empty = accept any device libmtp recognises.
CALIBRE_WEB_CLI_MTP_USB_IDS=

# How many daily metadata.db snapshots to retain under ${DATA_PATH}/snapshots/.
CALIBRE_WEB_CLI_SNAPSHOT_RETENTION_DAYS=14

# Where the container stores snapshots (and any future persistent app state).
DATA_PATH=./data
